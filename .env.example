# BaryGraph Kaikki PoC — copy to .env and adjust

# Project-owned Mongo (docker compose publishes 27017 inside the container to
# host port 27117 so we never touch any other local Mongo).
MONGO_URI=mongodb://localhost:27117/?directConnection=true
MONGO_DB=barygraph_poc
MONGO_COLLECTION=barygraph
# Safety: integration tests refuse to touch any DB whose name doesn't match this prefix.
MONGO_TEST_DB_PREFIX=barygraph_test_

OLLAMA_URL=http://localhost:11434
EMBED_MODEL=nomic-embed-text:v1.5
EMBED_DIM=768

KAIKKI_PATH=data/kaikki-en.jsonl
PARSED_DIR=data/parsed
PIPELINE_STATE_DIR=pipeline_state

# --- Batching ---
BATCH_SIZE=512
EMBED_BATCH_SIZE=64

# --- Pipeline thresholds (see CLAUDE.md) ---
Q_MIN_L15=0.72
DISAMBIG_THRESHOLD=0.72
META_BARY_COS_THRESHOLD=0.90
POLYSEMY_Q_FLOOR=0.40
WORD_LENGTH_LAMBDA=0.15

# --- L14 q_seeds (fermion order, CLAUDE.md Stage 5) ---
Q_SEED_CONTRADICTS=0.85
Q_SEED_APPLIES_TO=0.55
Q_SEED_IS_INSTANCE_OF=0.65
Q_SEED_EXTENDS=0.60
Q_SEED_COORDINATE_TERMS=0.70
Q_SEED_SYNONYMS=0.90

# --- Ollama timeouts ---
EMBED_TIMEOUT_SECONDS=120

LOG_LEVEL=INFO

# Set to 1 to replace ollama with deterministic fakes (CI / offline dev)
BARY_FAKE_EMBED=0
